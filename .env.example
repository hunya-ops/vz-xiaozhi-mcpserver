# 小智 AI MCP 接入点地址 (从 xiaozhi.me 控制台获取)
MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/v1/bridge?endpoint=xxx

# Navidrome 内部访问信息 (如果是 Docker host 模式且同台机器，建议用 127.0.0.1)
NAVIDROME_URL=http://127.0.0.1:4533
NAVIDROME_USER=your_username
NAVIDROME_PASS=your_password

# Navidrome 外部访问地址 (关键！小智机器人需要通过该地址获取封面和流媒体)
NAVIDROME_EXTERNAL_URL=https://music.your-domain.com
